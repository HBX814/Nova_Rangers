# =============================================================================
# CommunityPulse Nova Rangers — Environment Variables
# =============================================================================
# Copy this file to .env and fill in every value before running the application.
# Lines starting with # are comments describing where to obtain each credential.
# =============================================================================

# ---------------------------------------------------------------------------
# Google Cloud Platform
# ---------------------------------------------------------------------------
# GCP Project ID — find it at https://console.cloud.google.com/home/dashboard
GCP_PROJECT_ID=your-gcp-project-id

# GCP Region for Cloud Run, Firestore, Pub/Sub, BigQuery
GCP_REGION=asia-south1

# Path to the GCP service-account JSON key file.
# Create one at: IAM & Admin → Service Accounts → Keys → Add Key → JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ---------------------------------------------------------------------------
# Firebase / Firestore
# ---------------------------------------------------------------------------
# Path to your Firebase Admin SDK service-account JSON.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Firestore database ID (use "(default)" for the default database)
FIRESTORE_DATABASE_ID=(default)

# ---------------------------------------------------------------------------
# Google Gemini / Vertex AI  (used by the ADK agents)
# ---------------------------------------------------------------------------
# API key for Gemini models — obtain from https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your-gemini-api-key

# Model identifier used by all ADK agents
ADK_MODEL_NAME=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Google Cloud Pub/Sub
# ---------------------------------------------------------------------------
# Topic name for publishing new-need events
PUBSUB_TOPIC_NEW_NEED=new-need-created

# Subscription name the agents service pulls from
PUBSUB_SUBSCRIPTION_AGENTS=agents-new-need-sub

# ---------------------------------------------------------------------------
# Google Cloud BigQuery
# ---------------------------------------------------------------------------
# Dataset where analytic tables live
BIGQUERY_DATASET=community_pulse_analytics

# ---------------------------------------------------------------------------
# Google Cloud Trace / OpenTelemetry
# ---------------------------------------------------------------------------
# Set to "true" to enable exporting traces to Cloud Trace
ENABLE_CLOUD_TRACE=true

# ---------------------------------------------------------------------------
# Upstash Redis  (rate-limiting & caching)
# ---------------------------------------------------------------------------
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# ---------------------------------------------------------------------------
# Resend  (transactional email)
# ---------------------------------------------------------------------------
# Sign up at https://resend.com/ → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging  (push notifications)
# ---------------------------------------------------------------------------
# Uses the same FIREBASE_CREDENTIALS_PATH above. No extra key needed.

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# JSON Web Token secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Backend Server
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# ---------------------------------------------------------------------------
# CORS — comma-separated origins allowed by the backend
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com

# ---------------------------------------------------------------------------
# GitHub Actions / CI-CD  (set these as GitHub repository secrets)
# ---------------------------------------------------------------------------
# GCP_SA_KEY  — base64-encoded service-account JSON used by deploy.yml
#   Create at: IAM & Admin → Service Accounts → Keys → Add Key → JSON
#   Then: cat key.json | base64   and paste the output into GitHub Secrets
# GCP_SA_KEY=<set in GitHub Secrets, not here>
