# Environment & secrets
.env
*.json
!package.json
!pubspec.yaml
!tsconfig.json
!analysis_options.yaml
!pyproject.toml
!firebase.json
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.uv/
*.lock
!uv.lock

# Flutter / Dart
frontend/.dart_tool/
frontend/.packages
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/android/.gradle/
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/.pub-cache/
frontend/pubspec.lock

# Node (if any)
node_modules/

# Docker
docker/*.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Coverage & Testing
.coverage
htmlcov/
.pytest_cache/
coverage/

# ChromaDB local persistence
chroma_data/

# Superset
dashboard/superset_home/
