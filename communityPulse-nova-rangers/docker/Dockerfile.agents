# =============================================================================
# Dockerfile — CommunityPulse Agents Service
# =============================================================================
# Runs the Google ADK agent pipeline as a standalone service that
# pulls messages from Pub/Sub and processes them through the pipeline.
# =============================================================================

FROM python:3.12-slim-bookworm AS base

# FIX: libgl1-mesa-glx not available in bookworm slim; use libgl1
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    tesseract-ocr-hin \
    libgl1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /app

# Copy dependency files
COPY backend/pyproject.toml backend/pyproject.toml
COPY backend/uv.lock* backend/

# Sync dependencies
WORKDIR /app/backend
RUN uv sync --frozen --no-dev 2>/dev/null || uv sync --no-dev

# FIX: Return to /app before copying source so COPY targets are consistent
WORKDIR /app

# Copy source code
COPY agents/ agents/
COPY backend/ backend/
COPY .env.example .env.example

# FIX: Run from /app so both `agents` and `backend` packages are on sys.path
CMD ["uv", "run", "--directory", "backend", "python", "-m", "agents.pipeline"]