# =============================================================================
# Dockerfile — CommunityPulse Agents Service
# =============================================================================
# Runs the Google ADK agent pipeline as a standalone service that
# pulls messages from Pub/Sub and processes them through the pipeline.
# =============================================================================

FROM python:3.12-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    tesseract-ocr-hin \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /app

# Copy dependency files
COPY backend/pyproject.toml backend/pyproject.toml
COPY backend/uv.lock* backend/

# Sync dependencies
WORKDIR /app/backend
RUN uv sync --frozen --no-dev 2>/dev/null || uv sync --no-dev

WORKDIR /app

# Copy source code
COPY agents/ agents/
COPY backend/ backend/
COPY .env.example .env.example

# Run the agent pipeline
CMD ["uv", "run", "python", "-m", "agents.pipeline"]
