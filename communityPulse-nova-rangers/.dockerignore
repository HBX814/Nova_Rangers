# Keep Docker build context minimal and avoid invalid/generated frontend assets
.git
.github
.idea
.vscode

# Python caches and envs
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.venv/
venv/
**/.venv/

# Frontend build artifacts (problematic for docker context packaging)
frontend/build/
frontend/.dart_tool/
frontend/.pub-cache/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies

# Node and logs
node_modules/
**/*.log
logs/

# Test artifacts and local outputs
coverage/
htmlcov/
.pytest_cache/
test_reports/

